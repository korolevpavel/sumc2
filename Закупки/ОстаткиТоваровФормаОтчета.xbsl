метод ДатаОтчетаПриИзменении(Источник: ПолеВвода<ДатаВремя>, Событие: СобытиеПриИзменении<ДатаВремя>)
    знч Отчет = Компоненты.ПросмотрОтчета.Отчет как ОстаткиТоваров
    // Установка значения параметра отчета
    Отчет.УстановитьЗначениеПараметра("ДатаОтчета", Событие.НовоеЗначение)
    // Отображение отчета с новым значением параметра
    Компоненты.ПросмотрОтчета.Обновить()
;